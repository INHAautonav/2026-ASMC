# Shell env for ROS bridge (container). Does NOT change MORAI UI.
export MORAI_BRIDGE_PORT="${MORAI_BRIDGE_PORT:-9090}"
export ROS_MASTER_URI="http://127.0.0.1:11311"
export ROS_IP="${ROS_IP:-127.0.0.1}"

# Hint IP for MORAI UI (not pushed to simulator). Safe under bash `set -u`.
if [ -z "${MORAI_BRIDGE_IP:-}" ]; then
  if [ -f /.dockerenv ]; then
    export MORAI_BRIDGE_IP="127.0.0.1"
    export MORAI_BRIDGE_IP_HINT="docker_use_localhost_for_windows_morai"
  else
    _ip=$(hostname -I 2>/dev/null | awk '{print $1}')
    export MORAI_BRIDGE_IP="${_ip:-127.0.0.1}"
  fi
fi
