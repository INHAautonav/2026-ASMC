<!--
  behavior_planner + Frenet planner + MPC 통합 실행.

  데이터 흐름:
    behavior_planner → /behavior/context → planner (behavior_bridge)
    planner → /planner/plan_feedback → behavior_planner
    planner → /frenet_planner/trajectory → mpc_node (신선하면 사용, 아니면 CSV fallback)

  mpc waypoint/ref 경로는 각 launch에서 $(find mpc_node)로 주입.
-->
<launch>
  <include file="$(find behavior_planner)/launch/behavior_node.launch" />
  <include file="$(find planner)/launch/planner_node.launch" />
  <include file="$(find mpc_node)/launch/mpc_node.launch" />
</launch>
